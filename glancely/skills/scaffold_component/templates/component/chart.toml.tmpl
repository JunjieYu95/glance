# {{title}} component — chart configuration for dashboard visualization
[chart]
type = "{{chart_type}}"
title = "{{title}}"

[chart.data]
source = "rows"
date_field = "created_at"
value_field = "{{first_numeric}}"

[chart.options]
color_scheme = "{{color_scheme}}"

[overview]
enabled = true
card_type = "stat"
label = "{{title}}"
data_key = "summary.total"
suffix = ""
