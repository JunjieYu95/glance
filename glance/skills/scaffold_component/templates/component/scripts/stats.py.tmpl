#!/usr/bin/env python3
"""{{name}}.stats — auto-generated dashboard payload."""

from __future__ import annotations

import json
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[4]
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

from glance.core.storage import get_connection


def build_stats() -> dict:
    with get_connection() as conn:
        total = conn.execute(
            "SELECT COUNT(*) AS c FROM {{name}}_entries"
        ).fetchone()["c"]
        last7 = conn.execute(
            "SELECT COUNT(*) AS c FROM {{name}}_entries "
            "WHERE created_at >= datetime('now', '-7 days')"
        ).fetchone()["c"]
        last_row = conn.execute(
            "SELECT created_at FROM {{name}}_entries ORDER BY created_at DESC LIMIT 1"
        ).fetchone()
        rows = [
            dict(r) for r in conn.execute(
                "SELECT * FROM {{name}}_entries ORDER BY created_at DESC LIMIT 10"
            ).fetchall()
        ]

    if total == 0:
        return {"freshness_hours": None, "status": "empty",
                "summary": {"total": 0, "last_7d": 0}, "rows": []}

    freshness_hours = None
    if last_row:
        from datetime import datetime
        last_dt = datetime.fromisoformat(last_row["created_at"])
        freshness_hours = round((datetime.utcnow() - last_dt).total_seconds() / 3600.0, 2)

    return {
        "freshness_hours": freshness_hours,
        "status": "ok",
        "summary": {"total": total, "last_7d": last7},
        "rows": rows,
    }


if __name__ == "__main__":
    print(json.dumps(build_stats(), indent=2, ensure_ascii=False, default=str))
